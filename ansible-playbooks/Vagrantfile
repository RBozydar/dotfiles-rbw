Vagrant.configure("2") do |config|
  config.vm.box = "cloud-image/ubuntu-26.04"
  config.vm.hostname = "dotfiles-test"

  config.vm.provider :libvirt do |v|
    v.memory = 4096
    v.cpus = 4
    v.machine_virtual_size = 40
  end

  config.vm.synced_folder "../home", "/home/vagrant/repo/dotfiles-rbw/home", type: "rsync"

  config.vm.provision "shell", inline: <<-SHELL
    # Grow partition and filesystem to use full disk
    growpart /dev/vda 1 || true
    resize2fs /dev/vda1 || xfs_growfs / || true
    apt-get update
    apt-get install -y python3 python3-pip
  SHELL

  config.vm.provision "ansible" do |ansible|
    ansible.playbook = "main.yml"
    ansible.extra_vars = {
      username: "vagrant",
      user_home: "/home/vagrant",
      repo_root: "/home/vagrant/repo/dotfiles-rbw",
      home_repo: "/home/vagrant/repo/dotfiles-rbw/home",
      ansible_ssh_user: "vagrant"
    }
    ansible.galaxy_role_file = "requirements.yml"
    ansible.galaxy_command = "ansible-galaxy install -r %{role_file}"
    ansible.compatibility_mode = "2.0"
    ansible.skip_tags = "nvidia"
  end
end
