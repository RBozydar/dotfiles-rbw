{
    "name": "quickshell-governance-tooling",
    "private": true,
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "format": "sh ./scripts/format.sh",
        "lint": "sh ./scripts/lint.sh",
        "lint:js": "eslint services scripts system --max-warnings=0",
        "arch-check": "sh ./scripts/arch-check.sh",
        "cutover-status": "sh ./scripts/cutover-status.sh",
        "integration-smoke": "sh ./scripts/integration-smoke.sh",
        "review": "sh ./scripts/review.sh",
        "verify": "sh ./scripts/verify.sh",
        "ci-verify": "CI=1 sh ./scripts/verify.sh",
        "migration-check": "sh ./scripts/migration-check.sh",
        "qmltest": "./scripts/qml-test.sh",
        "pycheck": "./scripts/python-check.sh",
        "format:docs": "prettier --config .prettierrc.json --ignore-path .prettierignore --write . ../../../.github/workflows/quickshell-verify.yml",
        "check:docs": "prettier --config .prettierrc.json --ignore-path .prettierignore --check . ../../../.github/workflows/quickshell-verify.yml",
        "format:toml": "taplo format pyproject.toml .taplo.toml",
        "check:toml": "taplo format --check pyproject.toml .taplo.toml"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@taplo/cli": "^0.7.0",
        "eslint": "^9.0.0",
        "globals": "^16.0.0",
        "prettier": "^3.0.0"
    }
}
