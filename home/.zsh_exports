export PATH=$HOME/bin:/usr/local/bin:$PATH
export PATH=$HOME/.local/bin:$PATH
export PATH=$PATH:/usr/local/go/bin
export PATH=$PATH:/usr/local/go/bin:$HOME/go/bin
export SEARXNG_BASE_URL=https://searxng.local.b47.bozydar.me
[ -f /home/rbw/.zsh_secrets ] && source /home/rbw/.zsh_secrets
export ENABLE_LSP_TOOL=1
export CLAUDE_ENABLE_LSP_TOOL=1
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
zstyle ':completion::complete:*' use-cache 1

# completions
zstyle ':completion:*' completer _expand _complete _ignored _correct _approximate
zstyle ':completion:*' matcher-list 'm:{[:lower:]}={[:upper:]} m:{[:lower:][:upper:]}={[:upper:][:lower:]} l:|=* r:|=*' 'm:{[:lower:]}={[:upper:]} r:|[._-]=** r:|=**' '' 'm:{[:lower:][:upper:]}={[:upper:][:lower:]}'
zstyle :compinstall filename '/home/rbw/.zshrc'

# export GTK_THEME=Arc-Dark
export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"
# llama.cpp CUDA build

function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}
export ORT_DYLIB_PATH="$HOME/ort_gpu/libonnxruntime.so"
export LD_LIBRARY_PATH="$HOME/ort_gpu${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export PATH="/home/rbw/.local/llama_cpp_compiled/cuda/bin:$PATH"
export LD_LIBRARY_PATH="/home/rbw/.local/llama_cpp_compiled/cuda/lib:$LD_LIBRARY_PATH"

export HA_URL=http://homeassistant.local.bozydar.me
